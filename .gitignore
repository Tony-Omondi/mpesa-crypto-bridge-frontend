# Dependencies — reinstalled inside container
node_modules/

# Expo generated files
.expo/
dist/
web-build/
expo-env.d.ts

# Android/iOS native builds — not needed in container
android/
ios/
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Environment — never bake secrets into the image
.env
.env.local
.env*.local

# Git
.git/
.gitignore

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# OS files
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo